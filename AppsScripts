function sortTableAscending() {
  var sheet = SpreadsheetApp.getActiveSheet();
  // Get the data range, assuming headers are in the first row (starts from row 2)
  var range = sheet.getRange("A2:F50");
  // Sort by column 1 (A) in ascending order (true)
  range.sort({column: 5, ascending: true});
}
